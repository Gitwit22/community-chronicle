# ═══════════════════════════════════════════════════════════════
# BACKEND SERVER
# ═══════════════════════════════════════════════════════════════
PORT=5000
NXTLVL_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:8080
NODE_ENV=development

# Optional: Local database for search analytics/logging
# Leave empty to proxy all requests to nxt-lvl-api
DATABASE_URL=

# ═══════════════════════════════════════════════════════════════
# FRONTEND - API Integration
# ═══════════════════════════════════════════════════════════════
# Point to the Community Chronicle backend (which proxies to nxt-lvl-api)
VITE_API_BASE_URL=http://localhost:5000/api

# URL of the Nxt Lvl Suite — unauthenticated users are redirected here to log in.
VITE_SUITE_URL=http://localhost:3000

# Core Document Intelligence API (direct browser operations)
VITE_DOC_INTEL_API_URL=http://localhost:4010
VITE_DOC_INTEL_API_TOKEN=replace_me
VITE_DOC_TYPE_CONFIDENCE_THRESHOLD=0.6

