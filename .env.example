# Frontend-only environment variables
# Point to the standalone Nxt Lvl Platform API.
# Include the /api prefix so client calls map directly to auth/documents endpoints.
VITE_API_BASE_URL=http://localhost:4000/api

# URL of the Nxt Lvl Suite — unauthenticated users are redirected here to log in.
VITE_SUITE_URL=http://localhost:3000

# Core Document Intelligence API (direct browser operations)
VITE_DOC_INTEL_API_URL=http://localhost:4010
VITE_DOC_INTEL_API_TOKEN=replace_me
VITE_DOC_TYPE_CONFIDENCE_THRESHOLD=0.6

# Llama extraction schemas by document class
# These cfg-* values are non-secret config IDs — safe to commit and set as wrangler vars.
VITE_LLAMA_SCHEMA_DOCUMENT_CLASSIFIER_RESULT=cfg-ab0cav8xvylvzr2j3vjnzev19l3u
