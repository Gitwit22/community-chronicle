# ═══════════════════════════════════════════════════════════════
# PAGE-FIRST INTAKE FEATURE FLAG
# ═══════════════════════════════════════════════════════════════
# When true, new uploads use the page-first flow (OriginalUpload →
# DocumentPage → DocumentPacket) instead of the legacy proxy.
COMMUNITY_CHRONICLE_PAGE_FIRST_INTAKE=false

# ═══════════════════════════════════════════════════════════════
# FRONTEND - API Integration
# ═══════════════════════════════════════════════════════════════
# Community Chronicle now talks directly to nxt-lvl-api.
VITE_API_BASE_URL=http://localhost:4000/api

# Platform base URL for Suite token exchange and org context routes.
VITE_PLATFORM_API_URL=http://localhost:4000

# URL of the Nxt Lvl Suite — unauthenticated users are redirected here to log in.
VITE_SUITE_URL=http://localhost:3000

# Doc type confidence threshold used only for UI hinting.
# Doc Intel/extraction calls are backend-only.
VITE_DOC_TYPE_CONFIDENCE_THRESHOLD=0.6

